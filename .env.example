# ═══════════════════════════════════════════════════════════════════════════════
#  Dria Node — Cloud API Proxy Configuration
#  Save as /root/dria-nodes/.env  (shared by all wallet folders)
#
#  Compatible with ollama-server-fake .env format:
#  VIKEY_API_URL / VIKEY_API_KEY / DEFAULT_MODEL are all accepted.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Cloud API Provider ────────────────────────────────────────────────────────
# URL dan key dari cloud provider yang kamu pakai.
# Nama variabel VIKEY_* dipertahankan agar kompatibel dengan setup lama.

# Hyperbolic — https://app.hyperbolic.xyz  (ada free tier)
VIKEY_API_URL=https://api.hyperbolic.xyz/v1
VIKEY_API_KEY=

# FPT Cloud / VIKEY
# VIKEY_API_URL=https://mkp-api.fptcloud.com/v1
# VIKEY_API_KEY=sk-Ur2r-...

# Together AI — https://api.together.xyz
# VIKEY_API_URL=https://api.together.xyz/v1
# VIKEY_API_KEY=

# OpenRouter — https://openrouter.ai
# VIKEY_API_URL=https://openrouter.ai/api/v1
# VIKEY_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
#  PANDUAN 3 VARIABEL MODEL
#  Ada 2 "dunia" yang harus dipahami:
#
#    Dria Network  →  Node kamu  →  Cloud Provider
#
#  1. DRIA_MODELS  = nama model yang kamu IKLANKAN ke jaringan Dria
#                   (Dria router akan kirim task model ini ke kamu)
#
#  2. DEFAULT_MODEL = model NYATA di cloud provider yang menjalankan inference
#                    (semua task dari DRIA_MODELS diteruskan ke sini)
#
#  3. PROXY_MODELS  = OPSIONAL — override DEFAULT_MODEL per Dria model
#                    (berguna kalau DRIA_MODELS > 1 dan mau pakai cloud model
#                     berbeda per task agar lebih hemat)
#
#  Contoh paling simpel (1 model):
#    DRIA_MODELS=qwen3.5:9b
#    DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct
#    PROXY_MODELS=                    ← kosong, tidak perlu
#    → semua task qwen3.5:9b → Llama 70B
#
#  Contoh multi-model dengan override:
#    DRIA_MODELS=qwen3.5:9b,lfm2.5:1.2b,nanbeige:3b
#    DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct
#    PROXY_MODELS=lfm2.5:1.2b=Qwen/Qwen2.5-1.5B-Instruct,nanbeige:3b=Qwen/Qwen2.5-3B-Instruct
#    → task qwen3.5:9b   → Llama 70B    (dari DEFAULT_MODEL)
#    → task lfm2.5:1.2b  → Qwen 1.5B   (dari PROXY_MODELS, lebih murah)
#    → task nanbeige:3b  → Qwen 3B      (dari PROXY_MODELS)
# ─────────────────────────────────────────────────────────────────────────────

# Model nyata di cloud provider yang menjalankan inference.
# Semua task Dria diteruskan ke model ini (kecuali yang di-override PROXY_MODELS).
#
# Hyperbolic  : meta-llama/Llama-3.3-70B-Instruct  ← recommended
#             : Qwen/Qwen2.5-72B-Instruct
#             : Qwen/Qwen2.5-7B-Instruct            ← lebih murah
# FPT Cloud   : Qwen2.5-Coder-32B-Instruct
# Together AI : meta-llama/Llama-3.3-70B-Instruct-Turbo
# OpenRouter  : meta-llama/llama-3.3-70b-instruct
DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Nama model yang diiklankan ke jaringan Dria (comma-separated).
# HARUS menggunakan nama resmi Dria di bawah ini — bukan nama cloud provider.
#
# Available Dria model names:
#   Text   : lfm2.5:1.2b  nanbeige:3b  locooperator:4b  lfm2:24b-a2b
#   Vision : qwen3.5:9b   qwen3.5:27b  qwen3.5:35b-a3b  lfm2.5-vl:1.6b
#   Audio  : lfm2.5-audio:1.5b
DRIA_MODELS=qwen3.5:9b

# Override cloud model per Dria model name (OPSIONAL, kosongkan jika tidak perlu).
# Format : dria_name=cloud_name,dria_name2=cloud_name2
# Contoh : qwen3.5:9b=Qwen/Qwen2.5-7B-Instruct,lfm2.5:1.2b=Qwen/Qwen2.5-1.5B-Instruct
# Jika kosong, semua task pakai DEFAULT_MODEL di atas.
PROXY_MODELS=

# ── Node Config ───────────────────────────────────────────────────────────────
# Jumlah proses node per wallet folder (= jumlah services di docker-compose).
# Lebih banyak = lebih banyak task paralel yang bisa diterima per wallet.
NODE_COUNT=5

# Max concurrent inference tasks per node instance
DRIA_MAX_CONCURRENT=4

# ── Runtime ───────────────────────────────────────────────────────────────────
RUST_LOG=info

# NODE_PORT hanya untuk referensi — tidak dipakai oleh proxy node
NODE_PORT=14441
