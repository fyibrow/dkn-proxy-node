# ═══════════════════════════════════════════════════════════════════════════════
#  Dria Node — Cloud API Proxy Configuration
#  Save as /root/dria-nodes/.env  (shared by all wallet folders)
#
#  Compatible with ollama-server-fake .env format:
#  VIKEY_API_URL / VIKEY_API_KEY / DEFAULT_MODEL are all accepted.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Cloud API ─────────────────────────────────────────────────────────────────
# Choose your provider and set VIKEY_API_URL + VIKEY_API_KEY below.
# These names work like in ollama-server-fake — copy your old .env as-is.

# Hyperbolic — https://app.hyperbolic.xyz  (free tier)
VIKEY_API_URL=https://api.hyperbolic.xyz/v1
VIKEY_API_KEY=

# FPT Cloud / VIKEY (your current provider)
# VIKEY_API_URL=https://mkp-api.fptcloud.com/v1
# VIKEY_API_KEY=sk-Ur2r-...

# Together AI — https://api.together.xyz
# VIKEY_API_URL=https://api.together.xyz/v1
# VIKEY_API_KEY=

# OpenRouter — https://openrouter.ai
# VIKEY_API_URL=https://openrouter.ai/api/v1
# VIKEY_API_KEY=

# ── Cloud Model ───────────────────────────────────────────────────────────────
# The real model that handles inference on the cloud provider.
# Same meaning as DEFAULT_MODEL in ollama-server-fake.
#
# Hyperbolic  : meta-llama/Llama-3.3-70B-Instruct  ← recommended
#             : Qwen/Qwen2.5-72B-Instruct
#             : Qwen/Qwen2.5-7B-Instruct
# FPT Cloud   : Qwen2.5-Coder-32B-Instruct
# Together AI : meta-llama/Llama-3.3-70B-Instruct-Turbo
# OpenRouter  : meta-llama/llama-3.3-70b-instruct

DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ── Node Config ───────────────────────────────────────────────────────────────
# How many virtual node processes to run per wallet folder.
# Higher = more parallel tasks accepted per wallet (uses more API credits).
# Equivalent to having N services in each docker-compose.yml.
NODE_COUNT=5

# Dria network model names to advertise (comma-separated).
# Available: qwen3.5:9b  qwen3.5:27b  qwen3.5:35b-a3b  lfm2.5:1.2b
#            lfm2.5-vl:1.6b  lfm2.5-audio:1.5b  lfm2:24b-a2b
#            nanbeige:3b  locooperator:4b
DRIA_MODELS=qwen3.5:9b

# Max concurrent inference tasks per node instance
DRIA_MAX_CONCURRENT=4

# Optional per-model cloud model override (comma-separated dria_name=cloud_name)
# Example: qwen3.5:9b=Qwen/Qwen2.5-7B-Instruct,lfm2.5:1.2b=Qwen/Qwen2.5-1.5B-Instruct
PROXY_MODELS=

# ── Runtime ───────────────────────────────────────────────────────────────────
# Log verbosity: error, warn, info, debug
RUST_LOG=info

# NODE_PORT is kept for reference only — not used by the proxy node
NODE_PORT=14441
